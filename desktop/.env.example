# Copy this file to `.env` and fill in your Supabase project values.
# The anon key is safe to ship in a desktop client: row level security on the
# Supabase side (see supabase/schema.sql) is what actually protects data.

SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_ANON_KEY=YOUR-anon-public-key
